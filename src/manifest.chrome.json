{
  "manifest_version": 3,
  "name": "Claude RTL Responder",
  "version": "0.1.0",
  "description": "تحسين عرض النصوص العربية في Claude.ai - Improve Arabic text display on Claude.ai",
  "minimum_chrome_version": "88",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://claude.ai/*",
    "*://*.claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Claude RTL Responder"
  },
  "commands": {
    "toggle-mode": {
      "suggested_key": {
        "default": "Alt+G"
      },
      "description": "Toggle between Arabic and English mode"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+O"
      },
      "description": "Open the Claude RTL Responder popup"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://claude.ai/*",
        "*://*.claude.ai/*"
      ],
      "js": [
        "common/browser-polyfill.js",
        "content/detector.js",
        "content/observer.js",
        "content/content.js"
      ],
      "css": [
        "styles/rtl.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

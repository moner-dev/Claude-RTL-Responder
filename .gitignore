# Operating System Files
Thumbs.db
.DS_Store
Desktop.ini
*~

# IDE / Editor Files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# Build & Distribution
build/
dist/
*.min.js
*.min.css

# Firefox Extension Specific
web-ext-artifacts/
artifacts/
*.xpi
*.zip
firefox-profile/
.web-extension-id

# Testing
coverage/
.nyc_output/
test-results/

# Environment & Secrets
.env
.env.local
*.pem
*.key
secrets.json

# Logs
logs/
*.log

# Temporary Files
tmp/
temp/
.tmp/
.cache/
*.bak
*.backup

# Development notes
NOTES.md
TODO.local.md
dev-notes/

# Large media files (upload to YouTube/GitHub Releases instead)
docs/demo-video.webm
*.webm
